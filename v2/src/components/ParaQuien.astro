---
const positivo = [
  { text: 'Tenés un negocio que factura y querés tener el control', bold: true },
  'Trabajás en producción, fabricación o compraventa',
  'Tu información está desparramada y querés un solo lugar',
  'Ya tenés equipo o estás empezando a crecer',
  'Valorás soluciones simples que realmente se usan',
  'Buscás un socio que te acompañe, no solo un proveedor',
];

const negativo = [
  'Buscás una planilla simple para una sola cosa',
  'Necesitás algo listo para hoy mismo (los sistemas a medida llevan tiempo)',
  'Querés la opción más barata, sin importar la calidad',
  'Esperás resultados sin invertir tiempo en el proceso',
  'Sos una empresa grande con departamento de IT propio',
];
---

<section class="py-20 sm:py-28 bg-slate-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <div class="text-center mb-14">
      <h2 class="reveal text-3xl sm:text-4xl font-bold text-slate-900 mb-4">
        ¿Xestion es para tu negocio?
      </h2>
      <p class="reveal section-subheading !mb-0">
        Trabajamos con PyMEs, emprendedores y productores que quieren orden de verdad. No somos para todos, y está bien.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">

      {/* Positivo */}
      <div class="reveal-left bg-white rounded-2xl border border-emerald-100 p-7 shadow-sm">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-full bg-emerald-100 flex items-center justify-center">
            <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-emerald-800">Xestion es para vos si...</h3>
        </div>
        <ul class="space-y-3">
          {positivo.map((item) => {
            const text = typeof item === 'string' ? item : item.text;
            const bold = typeof item !== 'string' && item.bold;
            return (
              <li class="flex items-start gap-3 text-sm text-slate-600">
                <svg class="w-4 h-4 text-emerald-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class={bold ? 'font-bold text-slate-700' : ''}>{text}</span>
              </li>
            );
          })}
        </ul>
      </div>

      {/* Negativo */}
      <div class="reveal-right bg-white rounded-2xl border border-red-100 p-7 shadow-sm">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center">
            <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-red-800">No es para vos si...</h3>
        </div>
        <ul class="space-y-3">
          {negativo.map((item) => (
            <li class="flex items-start gap-3 text-sm text-slate-600">
              <svg class="w-4 h-4 text-red-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>
</section>
