---
import { OPCIONES_TRABAJO, CONTACTO } from '@data/config';

const iconPaths: Record<string, string> = {
  Excel: 'M3 10h18M3 14h18M10 4v16M3 4h18a1 1 0 011 1v14a1 1 0 01-1 1H3a1 1 0 01-1-1V5a1 1 0 011-1z',
  Globe: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9',
  Rocket: 'M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 00-2.91-.09zM12 15l-3-3M22 2l-7.5 7.5M15 2a4 4 0 00-4 4v2l-4 4h6l4-4h2a4 4 0 004-4V2z',
};

const cardAccents = [
  { border: 'border-t-4 border-yellow-400', badge: 'bg-yellow-400 text-slate-900', icon: 'text-yellow-500', iconBg: 'bg-yellow-50' },
  { border: 'border-t-4 border-violet-500', badge: 'bg-violet-500 text-white',   icon: 'text-violet-600', iconBg: 'bg-violet-50' },
  { border: 'border-t-4 border-brand-500', badge: 'bg-brand-500 text-white',     icon: 'text-brand-600', iconBg: 'bg-brand-50'  },
];
---

<section class="py-20 sm:py-28 bg-slate-100">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <div class="text-center mb-14">
      <h2 class="reveal text-3xl sm:text-4xl font-bold text-slate-900 mb-4">
        Opciones para ordenar tu negocio y tomar decisiones con más claridad
      </h2>
      <p class="reveal section-subheading !mb-0">
        Tres formas claras de avanzar, según tu momento y tu equipo.
      </p>
    </div>

    <div class="reveal-stagger grid md:grid-cols-3 gap-6 max-w-5xl mx-auto mt-6">
      {OPCIONES_TRABAJO.map((opcion, i) => {
        const accent = cardAccents[i] ?? cardAccents[0];
        return (
        <div class={`relative flex flex-col pt-12 px-5 sm:px-7 pb-7 rounded-2xl transition-all duration-300 bg-white shadow-md hover:shadow-xl hover:-translate-y-1 ${accent.border}`}>
          {opcion.badge && (
            <div class={`absolute -top-4 left-1/2 -translate-x-1/2 w-[85%] text-center px-3 py-1 text-xs font-semibold rounded-full shadow-md leading-snug ${accent.badge}`}>
              {opcion.badge}
            </div>
          )}

          {/* Icon */}
          <div class={`w-12 h-12 rounded-xl flex items-center justify-center mb-5 ${accent.iconBg}`}>
            {opcion.icono === 'Excel' ? (
              <svg class="w-8 h-8" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="32" height="32" rx="6" fill="#217346"/>
                <path d="M18 8h8v4h-8zM18 14h8v4h-8zM18 20h8v4h-8z" fill="white" opacity="0.3"/>
                <path d="M18 8h8v16h-8z" fill="none" stroke="white" stroke-width="0.5" opacity="0.4"/>
                <line x1="22" y1="8" x2="22" y2="24" stroke="white" stroke-width="0.5" opacity="0.4"/>
                <line x1="18" y1="12" x2="26" y2="12" stroke="white" stroke-width="0.5" opacity="0.4"/>
                <line x1="18" y1="16" x2="26" y2="16" stroke="white" stroke-width="0.5" opacity="0.4"/>
                <line x1="18" y1="20" x2="26" y2="20" stroke="white" stroke-width="0.5" opacity="0.4"/>
                <path d="M7 9l3.5 7L7 23h3l2-4.5L14 23h3l-3.5-7L17 9h-3l-2 4.5L10 9H7z" fill="white"/>
              </svg>
            ) : (
              <svg class={`w-6 h-6 ${accent.icon}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d={iconPaths[opcion.icono] || iconPaths.Globe}></path>
              </svg>
            )}
          </div>

          <h3 class="text-xl font-bold mb-2 text-slate-800">
            {opcion.titulo}
          </h3>
          <p class="text-sm mb-5 text-slate-500">
            {opcion.descripcion}
          </p>

          <ul class="space-y-2.5 mb-7 flex-1">
            {opcion.features.map((f) => (
              <li class="flex items-start gap-2 text-sm text-slate-600">
                <svg class={`w-4 h-4 mt-0.5 shrink-0 ${accent.icon}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                {f}
              </li>
            ))}
          </ul>

          <a
            href={CONTACTO.whatsappUrl}
            target="_blank"
            rel="noopener"
            class="text-center py-3 px-5 rounded-xl font-semibold text-sm transition-all duration-200 bg-brand-500 text-white hover:bg-brand-600 shadow-md shadow-brand-500/20"
          >
            {opcion.cta}
          </a>
        </div>
        );
      })}
    </div>
  </div>
</section>
