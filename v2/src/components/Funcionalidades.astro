    border: 'border-rose-100',
  },
  {
    icono: 'sucursales',
    titulo: 'Múltiples sucursales y monedas',
    descripcion: 'Manejá distintos puntos de venta o depósitos desde un mismo sistema. Soporte para pesos, dólares y otras monedas con conversión automática.',
